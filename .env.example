# Vértice — Variáveis de ambiente
# Copie para .env e preencha com seus valores reais

# ===== Aplicação =====
APP_NAME=Vértice
APP_ENV=development            # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=troque-este-segredo-imediatamente-em-producao
APP_BASE_URL=http://localhost:8000

# ===== Banco =====
DATABASE_URL=sqlite+aiosqlite:///./data/vertice.db

# ===== Auth =====
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=480
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASSWORD=vertice2026

# ===== LLMs =====
# Sem chave preenchida, o adaptador entra em modo mock (útil para dev offline)
# OPENAI_API_KEY também é usada pelo módulo padrão Exploração SQL (Deep Agent).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

MARITACA_API_KEY=
MARITACA_MODEL=sabia-4
MARITACA_BASE_URL=https://chat.maritaca.ai/api

GAIA_API_KEY=
GAIA_MODEL=gaia-4b
GAIA_BASE_URL=

# ===== Roteador de modelos (política padrão) =====
ROUTER_DEFAULT_MODEL=sabia-4
ROUTER_FALLBACK_MODEL=gpt-4.1
ROUTER_CHEAP_MODEL=gaia-4b

# ===== Observabilidade =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

MLFLOW_TRACKING_URI=

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=vertice

# ===== Política (OPA) =====
OPA_URL=                       # vazio desativa o adaptador OPA

# ===== Guardrails =====
GUARDRAIL_INPUT_MAX_CHARS=20000
GUARDRAIL_INJECTION_BLOCK=true
GUARDRAIL_PII_REDACT=true
