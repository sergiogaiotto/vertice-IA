# Vértice — variáveis para PRODUÇÃO (VPS Hostinger)
#
# 1) Copie para .env.production
#       cp .env.production.example .env.production
# 2) Substitua TODOS os valores marcados como "TROCAR"
# 3) Gere segredos fortes:
#       openssl rand -hex 32     # APP_SECRET_KEY
#       openssl rand -base64 24  # POSTGRES_PASSWORD
# 4) Garanta que .env.production esteja no .gitignore (já está) e que as
#    permissões sejam 600 no servidor:
#       chmod 600 .env.production

# ============================================================
# Domínio + TLS — DOIS MODOS suportados
# ============================================================
#
# MODO 1 — Self-signed (default, útil pra primeiro deploy):
#     DOMAIN=
#     ACME_EMAIL=internal
#   Caddy emite cert pela CA interna; URL fica https://VPS_IP:8010 com
#   aviso de cert não confiável (clique "avançar"). Bom pra validar
#   stack antes de mexer em DNS.
#
# MODO 2 — Produção (Let's Encrypt):
#     DOMAIN=vertice.exemplo.com.br
#     ACME_EMAIL=ops@exemplo.com.br
#   Caddy emite cert real automaticamente; URL fica
#   https://DOMAIN:8010. Pré-requisitos: DNS A do DOMAIN apontando para
#   o IP da VPS, e porta 80 aberta no firewall (ACME challenge).
#
# Para alternar: edite os dois valores aqui (ou no painel do Hostinger
# Docker Manager) e reinicie o container caddy. O cert emitido fica
# salvo no volume `caddy_data` e sobrevive a redeploys.
DOMAIN=
ACME_EMAIL=internal

# ============================================================
# Portas públicas
# ============================================================
# Porta exposta. Default 8010.
#   - Stack default (docker-compose.yml + Caddy): porta HTTPS pública,
#     URL final fica https://${DOMAIN}:${PUBLIC_HTTPS_PORT}.
#     Para usar 443 (URL sem porta), defina 443 aqui.
#   - Stack HTTP-only (docker-compose.public-http.yml): porta HTTP pública,
#     URL final fica http://VPS_IP:${PUBLIC_HTTPS_PORT}.
PUBLIC_HTTPS_PORT=8010
# Porta HTTP só usada pelo Caddy do compose default para o ACME HTTP-01
# challenge do Let's Encrypt. No compose HTTP-only, esta variável é
# ignorada — a app já escuta direto na PUBLIC_HTTPS_PORT.
PUBLIC_HTTP_PORT=80

# ============================================================
# App
# ============================================================
APP_NAME=Vértice
APP_ENV=production
# OBRIGATÓRIO TROCAR — gere com: openssl rand -hex 32
APP_SECRET_KEY=TROCAR_GERE_COM_openssl_rand_hex_32
# Inclua a porta se não for 443 — links absolutos gerados pelo app dependem
# disso. No MODO 1 (self-signed), pode deixar vazio que o app trata como
# base URL relativa.
APP_BASE_URL=

# ============================================================
# Auth
# ============================================================
# Bootstrap do primeiro usuário: NÃO há credenciais default. Acesse /login
# em https://VPS_IP:8010 logo após o primeiro deploy — qualquer username
# e senha que você submeter cria o usuário ROOT. Anote-os com cuidado:
# essa é sua única credencial inicial.
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=480

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_DB=vertice
POSTGRES_USER=vertice
# OBRIGATÓRIO TROCAR — gere com: openssl rand -base64 24
POSTGRES_PASSWORD=TROCAR_GERE_COM_openssl_rand_base64_24

# DATABASE_URL é montada automaticamente do POSTGRES_* acima. Sobrescrever
# só se conectar a um Postgres EXTERNO (managed), por exemplo:
# DATABASE_URL=postgresql://user:pass@db.host.com:5432/vertice

# ============================================================
# Pool asyncpg
# ============================================================
PG_POOL_MIN_SIZE=5
PG_POOL_MAX_SIZE=20
PG_POOL_MAX_INACTIVE_CONNECTION_LIFETIME=300.0
PG_COMMAND_TIMEOUT=30.0
PG_STATEMENT_CACHE_SIZE=1024

# ============================================================
# Tuning Postgres (ajustar conforme RAM da VPS)
# Plano com 4GB RAM → shared_buffers 1GB, effective_cache_size 3GB
# Plano com 2GB RAM → shared_buffers 512MB, effective_cache_size 1.5GB
# Plano com 1GB RAM → manter padrões abaixo
# ============================================================
PG_MAX_CONNECTIONS=200
PG_SHARED_BUFFERS=256MB
PG_EFFECTIVE_CACHE_SIZE=1GB
PG_WORK_MEM=8MB
PG_MAINTENANCE_WORK_MEM=64MB
PG_MAX_WAL_SIZE=2GB
PG_LOG_MIN_DURATION_MS=1000

# ============================================================
# Resource limits dos containers (ajustar conforme plano da VPS)
# ============================================================
VERTICE_MEM_LIMIT=1g
VERTICE_CPU_LIMIT=1.5
VERTICE_MEM_RESERVE=256m
POSTGRES_MEM_LIMIT=1g
POSTGRES_CPU_LIMIT=1.0
POSTGRES_MEM_RESERVE=256m

# Uvicorn workers — regra geral: 2 × vCPU. Defaults para 2 (VPS 2 vCPU).
UVICORN_WORKERS=2

# ============================================================
# Backups
# ============================================================
# Quantos dias manter dumps em /var/backups/postgres (volume nomeado).
BACKUP_KEEP_DAYS=7
# Hora UTC para rodar pg_dump diariamente (3 = 03:00 UTC = 00:00 BRT).
BACKUP_AT_HOUR_UTC=3

# ============================================================
# LLMs (opcional — vazio = modo mock, app navegável sem chaves)
# ============================================================
# Azure OpenAI (substitui o cliente OpenAI direto — usado no fallback e
# no módulo Exploração SQL / Deep Agent).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=                       # ex: https://meu-recurso.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
MARITACA_API_KEY=
MARITACA_MODEL=sabia-4
MARITACA_BASE_URL=https://chat.maritaca.ai/api
GAIA_API_KEY=
GAIA_MODEL=gaia-4b
GAIA_BASE_URL=

# Roteador de modelos (política padrão)
ROUTER_DEFAULT_MODEL=sabia-4
ROUTER_FALLBACK_MODEL=gpt-4o
ROUTER_CHEAP_MODEL=gaia-4b

# ============================================================
# Observabilidade (opcional)
# ============================================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
MLFLOW_TRACKING_URI=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=vertice

# ============================================================
# Política (OPA) — vazio desativa
# ============================================================
OPA_URL=

# ============================================================
# Guardrails
# ============================================================
GUARDRAIL_INPUT_MAX_CHARS=20000
GUARDRAIL_INJECTION_BLOCK=true
GUARDRAIL_PII_REDACT=true

# ============================================================
# Versão da imagem (CD pin)
# ============================================================
# Se você usa CI que tagueia imagens (vertice:1.2.3), defina aqui. Caso
# contrário, 'latest' funciona — mas sem ponto de rollback nominal.
VERTICE_TAG=latest
